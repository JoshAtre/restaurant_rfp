# OpenAI
OPENAI_API_KEY=sk-...

# USDA FoodData Central (free key: https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=your_usda_key

# Google Places (optional — for distributor search)
GOOGLE_PLACES_API_KEY=your_google_key

# Email (for sending RFP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com

# Restaurant location (for distributor search radius)
RESTAURANT_CITY=New York
RESTAURANT_STATE=NY
RESTAURANT_ZIP=10001

# Database
DATABASE_URL=sqlite:///./data/rfp.db
